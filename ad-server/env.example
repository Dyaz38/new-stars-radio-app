# Application
APP_NAME=New Stars Radio Ad Server
VERSION=1.0.0
ENVIRONMENT=development
DEBUG=True

# Database
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/adserver_dev
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# Security (CHANGE IN PRODUCTION!)
SECRET_KEY=your-secret-key-change-in-production-minimum-32-characters-long

# Icecast listener proxy (optional overrides)
# ICECAST_STATUS_URL=http://newstarsradio.out.airtime.pro:8000/status.xsl
# ICECAST_MOUNT=/newstarsradio_a

# Airtime live-info (song like genre — server fetches if client omits genre)
# AIRTIME_LIVE_INFO_URL=https://newstarsradio.airtime.pro/api/live-info
# Schedule storage (server-local JSON file)
# SCHEDULE_STORAGE_PATH=data/radio_schedule.json
# Station events JSON (listener app Events modal + admin Events page)
# EVENTS_STORAGE_PATH=data/station_events.json
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8000

# Password reset (admin panel). Reset links use FRONTEND_ADMIN_URL + /reset-password?token=...
# Use HTTPS in production (OWASP). Example:
# FRONTEND_ADMIN_URL=https://newstarsadminpanel.vercel.app
# Password reset email — configure ONE of: Resend (easiest) OR SMTP
# RESEND_API_KEY=re_xxxx
# RESEND_FROM=New Stars Radio <onboarding@resend.dev>
#
# SMTP — if unset (and no Resend), reset URLs are logged server-side only
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# SMTP_FROM=New Stars Radio <your-email@gmail.com>
# SMTP_USE_TLS=true
# SMTP_USE_SSL=false

# File Upload
UPLOAD_DIR=static/ads
MAX_UPLOAD_SIZE=5242880
ALLOWED_EXTENSIONS=.jpg,.jpeg,.png,.gif,.webp

# Cloudflare R2 (optional - enables direct upload from PC on Railway)
# When set, creative images are stored in R2 instead of local disk.
# Get these from Cloudflare Dashboard → R2 → your bucket → Settings
# R2_ACCOUNT_ID=your-account-id
# R2_ACCESS_KEY_ID=your-access-key
# R2_SECRET_ACCESS_KEY=your-secret-key
# R2_BUCKET_NAME=your-bucket-name
# R2_PUBLIC_URL=https://pub-xxxxx.r2.dev

# Ad Serving
DEFAULT_AD_PRIORITY=5
AD_SELECTION_TIMEOUT=100

# Rate Limiting
RATE_LIMIT_REQUESTS=1000
RATE_LIMIT_WINDOW=60

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Redis (optional for MVP)
# REDIS_URL=redis://redis:6379/0
CACHE_TTL=300





