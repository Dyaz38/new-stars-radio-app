# Public API root (no trailing slash). Listener + ad banner use this.
# Production (Railway):
# VITE_AD_SERVER_URL=https://new-stars-radio-app-production.up.railway.app/api/v1
#
# Local backend:
# VITE_AD_SERVER_URL=http://localhost:8000/api/v1

# Custom domain (optional): after adding radio.yourdomain.com in Vercel, no change needed
# unless you move the API — then point VITE_AD_SERVER_URL at Railway (or api.yourdomain.com).

# Optional: Google AdSense fallback when your ad-server has no paid creative (house promo).
# Own paid campaigns always win. Applies to the top banner and Events modal.
# Create Display ad units in AdSense; publisher id must start with ca-pub-.
# Optional Google AdSense fallback when no paid ad is available (production domain only).
# Preview *.vercel.app deployments always show the built-in house promo banner instead.
# VITE_ADSENSE_PUBLISHER_ID=ca-pub-xxxxxxxxxxxxxxxx
# VITE_ADSENSE_BANNER_SLOT=1234567890
# VITE_ADSENSE_EVENTS_SLOT=0987654321

# Production smoke tests (from repo root):
# PLAYWRIGHT_BASE_URL=https://new-stars-radio-app.vercel.app npx playwright test app/e2e-tests/launch-smoke.spec.ts
