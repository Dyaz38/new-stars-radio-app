# Public API root (no trailing slash). Listener + ad banner use this.
# VITE_AD_SERVER_URL=https://your-railway-host.up.railway.app/api/v1

# Custom domain (optional): after adding radio.yourdomain.com in Vercel, no change needed
# unless you move the API — then point VITE_AD_SERVER_URL at Railway (or api.yourdomain.com).

# Production smoke tests (from repo root):
# PLAYWRIGHT_BASE_URL=https://new-stars-radio-app.vercel.app npx playwright test app/e2e-tests/launch-smoke.spec.ts
